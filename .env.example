# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ── Core Django ──────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-railway-domain.up.railway.app,localhost
ADMIN_EMAIL=admin@yourcompany.co.ke
ADMIN_PASSWORD=StrongPassword123!

# ── Database (Railway PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname

# ── Service auth (must match HR_SERVICE_KEY in the Next.js apps) ─────────────
HR_SERVICE_KEY=replace-with-a-strong-random-string
RBAC_STRICT=False

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── Celery / Redis ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://default:password@host:port/0
CELERY_RESULT_BACKEND=redis://default:password@host:port/0
CELERY_TASK_ALWAYS_EAGER=False

# ── Email (Resend SMTP) ──────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_your_resend_api_key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Sheer Logic HR <hr@yourdomain.co.ke>

# ── Africa's Talking (SMS + WhatsApp) ───────────────────────────────────────
AT_USERNAME=your_at_username
AT_API_KEY=your_at_api_key
AT_SENDER_ID=SheerLogic
AT_WHATSAPP_NUMBER=

# ── IntaSend (M-Pesa disbursements) ─────────────────────────────────────────
INTASEND_PUBLISHABLE_KEY=
INTASEND_SECRET_KEY=
INTASEND_SANDBOX=True

# ── PesaPal (legacy payment rail) ───────────────────────────────────────────
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_ID=
PESAPAL_SANDBOX=True

# ── Supabase Storage (payroll PDFs, Excel exports, signed documents) ─────────
# Generate S3 keys: Supabase Dashboard → Project Settings → Storage → S3 Access Keys
# Create a bucket named 'hr-media' (public) in Supabase Storage before first use.
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=hr-media

# ── DocuSeal (e-signatures on payslips) ─────────────────────────────────────
DOCUSEAL_BASE_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_DEMO_MODE=True

# ── Smile ID (facial check-in) ──────────────────────────────────────────────
SMILEID_PARTNER_ID=
SMILEID_API_KEY=
SMILEID_BASE_URL=https://testapi.smileidentity.com/v1
SMILEID_DEMO_MODE=True

# ── Payroll behaviour ────────────────────────────────────────────────────────
PAYMENT_DEMO_MODE=False
PAYROLL_REQUIRE_SIGNATURE=True
PUBLIC_API_BASE_URL=https://your-railway-domain.up.railway.app

# ── TimescaleDB (optional) ───────────────────────────────────────────────────
TIMESCALE_ENABLED=False
