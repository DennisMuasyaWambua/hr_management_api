# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: sqlite, set to 'postgresql' for production)
DB_ENGINE=sqlite
DB_NAME=hr_api
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# PesaPal Configuration
# Get these from https://developer.pesapal.com/
PESAPAL_CONSUMER_KEY=your-consumer-key
PESAPAL_CONSUMER_SECRET=your-consumer-secret
PESAPAL_IPN_ID=your-ipn-id
PESAPAL_SANDBOX=True

# TimescaleDB — spatio-temporal attendance logs from the PWA
# (separate Postgres instance with the timescaledb extension)
TIMESCALE_ENABLED=False
TIMESCALE_DB_NAME=hr_timeseries
TIMESCALE_DB_USER=postgres
TIMESCALE_DB_PASSWORD=
TIMESCALE_DB_HOST=localhost
TIMESCALE_DB_PORT=5433

# Email (Resend SMTP-compatible; console backend by default in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Sheer Logic HR <hr@yourdomain.com>

# Africa's Talking WhatsApp (Chat API); SMS uses AT_USERNAME/AT_API_KEY
AT_WHATSAPP_NUMBER=

# DocuSeal e-signature (set DOCUSEAL_DEMO_MODE=False with real credentials)
DOCUSEAL_BASE_URL=https://api.docuseal.com
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_DEMO_MODE=True

# Smile ID facial recognition (set SMILEID_DEMO_MODE=False with real creds)
SMILEID_PARTNER_ID=
SMILEID_API_KEY=
SMILEID_BASE_URL=https://testapi.smileidentity.com/v1
SMILEID_DEMO_MODE=True

# Public URL used in one-tap approval links (SMS/WhatsApp)
PUBLIC_API_BASE_URL=http://localhost:8000

# RBAC strict mode — enable once the dashboard forwards X-User-Role headers
RBAC_STRICT=False
